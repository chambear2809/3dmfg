#!/bin/sh
#
# Pre-push hook: prevent PRO code from being pushed to the public core repo.
# Install: git config core.hooksPath .githooks
#
# Git passes lines on stdin: <local-ref> <local-sha> <remote-ref> <remote-sha>

ZERO="0000000000000000000000000000000000000000"
PRO_FILES=""

while read local_ref local_sha remote_ref remote_sha
do
    # Skip branch deletions
    if [ "$local_sha" = "$ZERO" ]; then
        continue
    fi

    if [ "$remote_sha" = "$ZERO" ]; then
        # New branch — check all commits against main
        range="origin/main..$local_sha"
    else
        # Existing branch — check new commits only
        range="$remote_sha..$local_sha"
    fi

    # Collect changed file paths in this push range
    FILES=$(git diff --name-only "$range" 2>/dev/null | grep -E "^backend/app/pro/|^license-server/" || true)
    if [ -n "$FILES" ]; then
        PRO_FILES="$PRO_FILES
$FILES"
    fi
done

# Trim leading whitespace
PRO_FILES=$(echo "$PRO_FILES" | sed '/^$/d')

if [ -n "$PRO_FILES" ]; then
    echo ""
    echo "BLOCKED: PRO code detected in push to public repo!"
    echo ""
    echo "The following files must NOT be in the public core:"
    echo "$PRO_FILES"
    echo ""
    echo "PRO code belongs in the private repo (Blb3D/FilaOpsPRO-BLB3D_Production)."
    echo "If this is intentional, use --no-verify (not recommended)."
    echo ""
    exit 1
fi
