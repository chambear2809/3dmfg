#!/bin/bash
# T-REX Pre-Commit Hook — The Mechanical Wall
# Installed by T-REX into target repositories
# This is Law One at the OS level. No behavioral compliance needed.

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)

if [ -z "$BRANCH" ]; then
  # Allow commits during rebase, cherry-pick, or merge (all run in detached HEAD)
  if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ] || [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ] || [ -f "$GIT_DIR/MERGE_HEAD" ]; then
    exit 0
  fi
  echo "🦖 T-REX: WARNING — Detached HEAD state detected."
  echo "🦖 T-REX: Cannot verify branch protection. Blocking commit."
  exit 1
fi

PROTECTED_BRANCHES="main master production release"

for PROTECTED in $PROTECTED_BRANCHES; do
  if [ "$BRANCH" = "$PROTECTED" ]; then
    echo ""
    echo "🦖 ============================================"
    echo "🦖  T-REX: LAW ONE VIOLATION"
    echo "🦖  Attempted commit directly to '$BRANCH'"
    echo "🦖 ============================================"
    echo "🦖"
    echo "🦖  This branch is protected. All changes must"
    echo "🦖  go through a feature branch and PR."
    echo "🦖"
    echo "🦖  Fix:"
    echo "🦖    git stash"
    echo "🦖    git checkout -b feature/your-description"
    echo "🦖    git stash pop"
    echo "🦖    git add -A && git commit"
    echo "🦖"
    echo "🦖 ============================================"
    echo ""
    exit 1
  fi
done

echo "🦖 T-REX: Branch '$BRANCH' validated. Proceeding."
exit 0
