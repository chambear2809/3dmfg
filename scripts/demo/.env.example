# Copy this file to scripts/demo/.env.local and fill in the secrets.
# The demo wrapper auto-loads scripts/demo/.env and scripts/demo/.env.local.
# If you prefer to keep credentials elsewhere, set DEMO_ENV_FILE=/path/to/private-demo.env.

# === REQUIRED: Splunk Observability Cloud ===
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=               # API token (dashboards, events, ingest)
SPLUNK_INGEST_TOKEN=               # Ingest-only token (if your org separates API and ingest)
SPLUNK_RUM_ACCESS_TOKEN=           # Browser RUM token (optional, stored in K8s secret)
SPLUNK_NETWORK_EXPLORER_URL=

# === REQUIRED: ThousandEyes ===
THOUSANDEYES_BEARER_TOKEN=         # API bearer token
THOUSANDEYES_ACCOUNT_GROUP_ID=2114135

# Suggested demo agents discovered on 2026-04-07:
# Browser: 66 (Ashburn, VA cloud agent)
# HTTP/API: 1660330,1660331 (online enterprise agents in account group 2114135)
THOUSANDEYES_BROWSER_AGENT_IDS=66
THOUSANDEYES_HTTP_AGENT_IDS=1660330,1660331
THOUSANDEYES_API_AGENT_IDS=1660330,1660331
THOUSANDEYES_DASHBOARD_URL=

# === REQUIRED: Demo App ===
FRONTEND_URL=http://localhost:8080
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=C1sco12345
PUBLIC_API_BASE_URL=

# === OPTIONAL: ThousandEyes Test Pinning ===
# Reuse existing tests instead of creating new ones.
THOUSANDEYES_EXISTING_HTTP_SERVER_TEST_ID=
THOUSANDEYES_EXISTING_WEB_TRANSACTION_TEST_ID=
THOUSANDEYES_EXISTING_API_TEST_ID=
# Set to true when the account group is quota-locked and existing transaction tests
# must be referenced read-only instead of modified in place.
THOUSANDEYES_PIN_EXISTING_TRANSACTION_TESTS=false

# === OPTIONAL: ThousandEyes Enterprise Agent ===
# Set the account token to auto-install an in-cluster Enterprise Agent during deploy/setup.
THOUSANDEYES_ENTERPRISE_AGENT_ACCOUNT_TOKEN=
THOUSANDEYES_ENTERPRISE_AGENT_NAMESPACE=thousandeyes
THOUSANDEYES_ENTERPRISE_AGENT_NAME=filaops-demo-ea
THOUSANDEYES_ENTERPRISE_AGENT_STORAGE_CLASS=gp2
THOUSANDEYES_ENTERPRISE_AGENT_STORAGE_SIZE=20Gi
THOUSANDEYES_ENTERPRISE_AGENT_IMAGE=thousandeyes/enterprise-agent

# === OPTIONAL: Infrastructure Versions (pinned defaults) ===
# Uncomment to override the versions installed by `deploy`.
# CERT_MANAGER_VERSION=v1.17.1
# OTEL_OPERATOR_VERSION=0.75.0
# SPLUNK_OTEL_CHART_VERSION=0.113.0
# OTEL_CLUSTER_NAME=filaops-demo

# === OPTIONAL: Cilium / Isovalent ===
ISOVALENT_DASHBOARD_URL=
ISOVALENT_DROP_METRIC=
ISOVALENT_FLOW_METRIC=
ISOVALENT_NAMESPACE_DIMENSION=

# === OPTIONAL: General ===
KUBECTL_FLAGS=
# Set TEARDOWN_OTEL=true during teardown to also remove the OTel collector and operator.
# TEARDOWN_OTEL=false
